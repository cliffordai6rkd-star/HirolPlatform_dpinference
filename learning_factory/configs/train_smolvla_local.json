  "optimizer": null,
  "scheduler": null,
  "batch_size": 4,
  "num_workers": 4,
  "steps": 40000,
  "eval_freq": -1,
  "log_freq": 10,
  "save_checkpoint": true,
  "save_freq": 10000,
  "seed": 1000,
  "use_policy_training_preset": true,
  "output_dir": "outputs/train/fr3_smolvla_local",
  "wandb": {
    "enable": true
  }
}
