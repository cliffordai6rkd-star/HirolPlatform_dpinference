{
  "dataset": {
    "repo_id": "fr3_pick_and_place_3dmouse",
    "root": "/home/hanyu/code/HIROLRobotPlatform/dataset/assets/fr3_pick_and_place_3dmouse",
    "episodes": null,
    "streaming": false,
    "use_imagenet_stats": false,
    "image_transforms": {
      "enable": false
    },
